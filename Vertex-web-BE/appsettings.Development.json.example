{
  "// HƯỚNG DẪN": "Copy file này thành appsettings.Development.json rồi điền thông tin thật vào",

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=vertex_db;Username=postgres;Password=<YOUR_DB_PASSWORD>"
  },
  "Jwt": {
    "Key": "<YOUR_JWT_SECRET_KEY_AT_LEAST_32_CHARS>"
  },
  "EmailSettings": {
    "SenderEmail": "<YOUR_EMAIL>@gmail.com",
    "Username": "<YOUR_EMAIL>@gmail.com",
    "Password": "<YOUR_GMAIL_APP_PASSWORD>"
  },
  "GeminiSettings": {
    "ApiKey": "<YOUR_GEMINI_API_KEY_FROM_AISTUDIO>"
  },
  "PayOS": {
    "ClientId": "<YOUR_PAYOS_CLIENT_ID>",
    "ApiKey": "<YOUR_PAYOS_API_KEY>",
    "ChecksumKey": "<YOUR_PAYOS_CHECKSUM_KEY>",
    "ReturnUrl": "http://localhost:5173/dashboard",
    "CancelUrl": "http://localhost:5173/dashboard",
    "CheckoutExpiresMinutes": 30
  },
  "ExternalAuth": {
    "Google": {
      "ClientId": "<YOUR_GOOGLE_OAUTH_CLIENT_ID>"
    },
    "GitHub": {
      "ClientId": "<YOUR_GITHUB_OAUTH_CLIENT_ID>",
      "ClientSecret": "<YOUR_GITHUB_OAUTH_CLIENT_SECRET>"
    }
  }
}
